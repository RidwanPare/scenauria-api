# Base de données
DATABASE_URL=postgresql://scenauria:scenauria@localhost:5432/scenauria

# Redis
REDIS_URL=redis://localhost:6379

# Auth — JWT
JWT_SECRET=change_me_to_a_long_random_string_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_RESET_EXPIRES_IN=1h

# Auth — Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@scenauria.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stockage S3-compatible (Cloudflare R2 ou AWS S3)
S3_BUCKET=scenauria-assets
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=https://...r2.cloudflarestorage.com

# Worker
WORKER_CALLBACK_SECRET=change_me_to_a_random_string
WORKER_API_URL=http://localhost:3001

# Serveur
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
